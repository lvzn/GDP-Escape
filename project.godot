; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Escape"
run/main_scene="res://scenes/Game.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://dbxliusj6x7cq"

[autoload]

PlayerVariables="*uid://8p8qrvgvshuu"
AudioManager="*uid://cvao3guqdrhjj"
SceneManager="*uid://ul82clr4y7s1"

[display]

window/size/viewport_width=2560
window/size/viewport_height=1440
window/size/borderless=true
window/stretch/mode="viewport"
window/stretch/aspect="keep_height"
display_server/driver.linuxbsd="wayland"

[editor]

movie_writer/movie_file="/home/leevi/Projects/escape/trailer.avi"
version_control/plugin_name="GitPlugin"
version_control/autoload_on_startup=true

